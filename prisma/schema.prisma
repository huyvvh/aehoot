generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  questionSets QuestionSet[]
  folders      Folder[]
  gameSessions GameSession[]
  favorites    Favorite[]

  sourceDocuments SourceDocument[]
  generationJobs  GenerationJob[]
  explanationJobs ExplanationJob[]
}

model QuestionSet {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  isPublic    Boolean  @default(true)
  playCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  questions    Question[]
  gameSessions GameSession[]
  favorites    Favorite[]

  explanationJobs ExplanationJob[]

  @@index([authorId])
  @@index([isPublic, playCount])
  @@index([title])
}

model Question {
  id        String  @id @default(cuid())
  text      String
  imageUrl  String?
  timeLimit Int     @default(20)
  points    Int     @default(100)
  order     Int     @default(0)

  // Truy vết về tài liệu nguồn (lưu khi publish từ AI) để Agent giải thích đối chiếu.
  sourceQuote   String?
  sourceChunkId String?

  // Gắn cờ khi tài liệu nguồn cập nhật → nội dung câu có thể đã lỗi thời, cần rà soát.
  needsReview Boolean @default(false)

  questionSetId String
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  answers       Answer[]
  playerAnswers PlayerAnswer[]
  explanation   QuestionExplanation?

  @@index([questionSetId])
}

model Answer {
  id        String  @id @default(cuid())
  text      String
  isCorrect Boolean @default(false)
  order     Int     @default(0)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionSets QuestionSet[]

  @@index([userId])
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionSetId String
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  @@unique([userId, questionSetId])
}

model GameSession {
  id           String     @id @default(cuid())
  gameCode     String     @unique
  gameMode     GameMode
  status       GameStatus @default(WAITING)
  maxPlayers   Int        @default(150)
  currentIndex Int        @default(0)

  isHomework Boolean   @default(false)
  deadline   DateTime?

  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  hostId String
  host   User   @relation(fields: [hostId], references: [id], onDelete: Cascade)

  questionSetId String
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  players GamePlayer[]

  @@index([gameCode])
  @@index([hostId])
  @@index([status])
}

enum GameMode {
  CLASSIC
  RACE
  BATTLE_ROYALE
  CHALLENGE
}

enum GameStatus {
  WAITING
  IN_PROGRESS
  FINISHED
  CANCELLED
}

model GamePlayer {
  id           String   @id @default(cuid())
  nickname     String
  score        Int      @default(0)
  isEliminated Boolean  @default(false)
  joinedAt     DateTime @default(now())

  userId        String?
  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  answers PlayerAnswer[]

  @@index([gameSessionId])
  @@unique([gameSessionId, nickname])
}

model PlayerAnswer {
  id             String   @id @default(cuid())
  isCorrect      Boolean
  answeredAt     DateTime @default(now())
  timeTaken      Float
  selectedAnswer String?

  playerId String
  player   GamePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([playerId, questionId])
  @@index([playerId])
}

// ── AI Question Generator ────────────────────────────────────
// Upload tài liệu nghiệp vụ → sinh đề bằng GLM 5.2 → review → publish

model SourceDocument {
  id         String    @id @default(cuid())
  filename   String
  mimeType   String
  storageUrl String?
  rawText    String
  status     DocStatus @default(UPLOADED)
  createdAt  DateTime  @default(now())

  // Phiên bản hóa quy định ("hiện hành"): mã văn bản, ngày hiệu lực, trạng thái.
  regulationCode String?
  effectiveDate  DateTime?
  regStatus      RegStatus @default(EFFECTIVE)

  // Bản mới thay thế bản này (self-relation).
  supersededById String?
  supersededBy   SourceDocument?  @relation("Supersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes     SourceDocument[] @relation("Supersession")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chunks DocumentChunk[]
  jobs   GenerationJob[]

  @@index([userId])
  @@index([regStatus])
}

enum RegStatus {
  EFFECTIVE  // đang hiệu lực
  SUPERSEDED // đã bị bản mới thay thế
}

model DocumentChunk {
  id      String @id @default(cuid())
  order   Int
  content String

  documentId String
  document   SourceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model GenerationJob {
  id            String    @id @default(cuid())
  config        Json
  status        JobStatus @default(QUEUED)
  progress      Int       @default(0)
  error         String?
  draft         Json?
  questionSetId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  documentId String
  document   SourceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
  @@index([status])
}

enum DocStatus {
  UPLOADED
  PARSED
  CHUNKED
  FAILED
}

enum JobStatus {
  QUEUED
  PROCESSING
  REVIEW
  DONE
  FAILED
}

// ── Agent giải thích & cập nhật kiến thức ────────────────────
// Sinh giải thích đáp án có trích dẫn nguồn → review bắt buộc → CURRENT.

model QuestionExplanation {
  id                String            @id @default(cuid())
  body              String            // Giải thích: vì sao đáp án đúng / các phương án khác sai
  status            ExplanationStatus @default(DRAFT)
  grounded          Boolean           @default(false)
  basedOnDocumentId String?           // Bản tài liệu/quy định làm căn cứ (phục vụ phiên bản hóa ở P3)
  reviewedAt        DateTime?
  reviewedById      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  questionId String   @unique
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  citations ExplanationCitation[]

  @@index([status])
}

model ExplanationCitation {
  id            String  @id @default(cuid())
  quote         String  // Trích dẫn nguyên văn làm căn cứ
  chunkId       String? // DocumentChunk nguồn (nếu có)
  documentId    String?

  explanationId String
  explanation   QuestionExplanation @relation(fields: [explanationId], references: [id], onDelete: Cascade)

  @@index([explanationId])
}

enum ExplanationStatus {
  DRAFT        // vừa sinh, chưa duyệt
  NEEDS_REVIEW // không grounded / thiếu nguồn → cần người soát kỹ
  CURRENT      // đã duyệt, đang hiệu lực
  STALE        // quy định/thị trường đổi → cần cập nhật (P3+)
}

model ExplanationJob {
  id        String    @id @default(cuid())
  status    JobStatus @default(QUEUED)
  progress  Int       @default(0)
  total     Int       @default(0)
  done      Int       @default(0)
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionSetId String
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionSetId])
  @@index([status])
}
