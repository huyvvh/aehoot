# ─────────────────────────────────────────────────────────────
# AEHoot — Environment Variables
# Copy sang .env.local cho local dev, hoặc set trong Railway
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# Railway: tự động inject khi thêm PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Redis (Upstash) ───────────────────────────────────────────
# Lấy tại https://console.upstash.com → tạo Redis DB → REST API
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── Auth ──────────────────────────────────────────────────────
# Sinh ngẫu nhiên: openssl rand -base64 32
JWT_SECRET="change-me-to-random-32-chars-minimum"

# ── Cloudinary ────────────────────────────────────────────────
# Lấy tại https://cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── App URLs ──────────────────────────────────────────────────
# Production: URL Railway assign (vd: https://aehoot.up.railway.app)
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"
# Custom server: Socket.IO và Next.js chạy cùng port
NEXT_PUBLIC_SOCKET_URL="https://your-app.up.railway.app"

# ── Node ──────────────────────────────────────────────────────
NODE_ENV="production"
